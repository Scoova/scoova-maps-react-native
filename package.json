{
  "name": "@scoova/maps-react-native",
  "version": "1.1.2",
  "description": "Scoova map SDK for React Native \u2014 wraps @MapLibre/@maplibre/maplibre-react-native with Scoova tile/style defaults, route + marker helpers, and standalone static-map URL builders.",
  "main": "lib/typescript/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src/",
    "lib/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "license": "Apache-2.0",
  "author": "Scoova <info@scoo-va.info>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Scoova/scoova-maps-react-native.git"
  },
  "bugs": {
    "url": "https://github.com/Scoova/scoova-maps-react-native/issues"
  },
  "homepage": "https://github.com/Scoova/scoova-maps-react-native#readme",
  "keywords": [
    "scoova",
    "maps",
    "MapLibre",
    "react-native",
    "static-map"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@MapLibre/@maplibre/maplibre-react-native": "*",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
